root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

# Namespaces
csharp_style_namespace_declarations = file_scoped:warning

# 'var' nie benutzen - immer explizite Typen
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# Null-Handling
dotnet_style_null_propagation = true:warning
dotnet_style_coalesce_expression = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning

# using-Direktiven außerhalb des Namespace
csharp_using_directive_placement = outside_namespace:warning

# Kein 'this.' erzwingen
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Geschweifte Klammern auch bei einzeiligen Blöcken
csharp_prefer_braces = true:warning

# Neue Zeile vor öffnender geschweifter Klammer
csharp_new_line_before_open_brace = all

# using-Sortierung
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true

# Namenskonventionen: private Felder mit Unterstrich
dotnet_naming_rule.private_fields_should_be_camel_case.severity = warning
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = underscore_camel_case

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
