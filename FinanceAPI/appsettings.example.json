{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5281"
      },
      "Https": {
        "Url": "https://localhost:7185"
      }
    }
  },
  "DatabaseSettings": {
    "Provider": "sqlite"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/finance.db"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE-ME-MIN-32-CHARACTERS-LONG!!",
    "Issuer": "FinanceAPI",
    "Audience": "FinanceApp",
    "ExpirationHours": 24
  },
  "RateLimitSettings": {
    "AuthPermitLimit": 10,
    "AuthWindowMinutes": 1
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:5500", "http://127.0.0.1:5500" ]
  },
  "DefaultCategories": [
    { "Name": "Gehalt",       "Type": "income",  "Color": "#27ae60" },
    { "Name": "Freelance",    "Type": "income",  "Color": "#2ecc71" },
    { "Name": "Miete",        "Type": "expense", "Color": "#e74c3c" },
    { "Name": "Lebensmittel", "Type": "expense", "Color": "#e67e22" },
    { "Name": "Transport",    "Type": "expense", "Color": "#3498db" },
    { "Name": "Unterhaltung", "Type": "expense", "Color": "#9b59b6" },
    { "Name": "Gesundheit",   "Type": "expense", "Color": "#1abc9c" }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
